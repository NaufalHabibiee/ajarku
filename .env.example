# ---------------------------------------------------------------------------
# Database (Supabase Postgres)
# ---------------------------------------------------------------------------
# Pooled connection (PgBouncer) used by the app at runtime.
DATABASE_URL="postgresql://postgres.PROJECT:PASSWORD@aws-region.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Direct connection used by Prisma Migrate.
DIRECT_URL="postgresql://postgres.PROJECT:PASSWORD@aws-region.pooler.supabase.com:5432/postgres"

# ---------------------------------------------------------------------------
# Supabase
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ---------------------------------------------------------------------------
# Midtrans (platform default, overridden per tenant)
# ---------------------------------------------------------------------------
MIDTRANS_SERVER_KEY=
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY=
MIDTRANS_IS_PRODUCTION=false

# ---------------------------------------------------------------------------
# Bunny Stream (platform default)
# ---------------------------------------------------------------------------
BUNNY_API_KEY=
BUNNY_STREAM_LIBRARY_ID=

# ---------------------------------------------------------------------------
# Resend (email)
# ---------------------------------------------------------------------------
RESEND_API_KEY=

# ---------------------------------------------------------------------------
# App
# ---------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Root domain used to resolve tenant subdomains (e.g. "yourdomain.com").
# On Vercel set this to your deployment domain, e.g. "ajarku-azure.vercel.app".
NEXT_PUBLIC_ROOT_DOMAIN=localhost:3000
# Single-tenant deployments (one domain, no per-tenant subdomains): set this to
# the tenant slug to show on the root domain, e.g. "demo". Leave empty for a
# true multi-tenant subdomain setup.
DEFAULT_TENANT_SLUG=
NEXTAUTH_SECRET=
